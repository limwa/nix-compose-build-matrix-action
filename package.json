{
  "name": "javascript-action",
  "description": "GitHub Actions JavaScript Template",
  "version": "0.0.0",
  "packageManager": "pnpm@10.28.2",
  "author": "",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/actions/javascript-action#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actions/javascript-action.git"
  },
  "bugs": {
    "url": "https://github.com/actions/javascript-action/issues"
  },
  "keywords": [
    "actions"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bundle": "node --run format:write && node --run typecheck && node --run package",
    "coverage": "make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "local-action": "local-action . dist/index.js .env",
    "typecheck": "tsc --noEmit",
    "package": "rimraf ./dist && rolldown --config rolldown.config.js",
    "package:watch": "node --run package -- --watch",
    "test": "vitest",
    "all": "node --run format:write && node --run lint && node --run test && node --run coverage && node --run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "effect": "^3.19.19"
  },
  "devDependencies": {
    "@github/local-action": "^7.0.1",
    "@types/node": "^25.3.3",
    "@vitest/coverage-istanbul": "4.0.18",
    "make-coverage-badge": "^1.2.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rolldown": "1.0.0-rc.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
